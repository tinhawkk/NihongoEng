# =============================================
# VOCABULARY QUIZ - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values

# =============================================
# Google Sheets Configuration
# =============================================
# Published Google Sheets base URL
VITE_SHEET_PUBLISHED_BASE=https://docs.google.com/spreadsheets/d/e/YOUR_SHEET_ID/pub

# Google Apps Script Web App URLs for data sync
VITE_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# API secret for authentication (optional)
SHEETS_API_SECRET=your-secret-key-here
VITE_WEBAPP_SECRET=your-webapp-secret

# =============================================
# Sheet IDs (gids) for each vocabulary level
# =============================================
# Get sheet ID from URL: ...#gid=XXXXXXXXX
VITE_SHEET_ID_ENG=XXXXXXXXX
VITE_SHEET_ID_N5=XXXXXXXXX
VITE_SHEET_ID_N4=XXXXXXXXX
VITE_SHEET_ID_N3=XXXXXXXXX
VITE_SHEET_ID_N2=XXXXXXXXX
VITE_SHEET_ID_N1=XXXXXXXXX
VITE_SHEET_ID_JLPT=XXXXXXXXX
VITE_SHEET_ID_GRAMMAR=XXXXXXXXX

# =============================================
# Application Configuration
# =============================================
# App title displayed in browser/UI
VITE_APP_TITLE=Vocabulary Quiz

# Default sheet/level to load on startup
VITE_DEFAULT_GID=170422884

# Theme preference (light/dark)
VITE_DEFAULT_THEME=light

# Enable seasonal effects (Tet, Lunar New Year, etc.)
VITE_ENABLE_SEASONAL_EFFECTS=true

# =============================================
# Development Configuration
# =============================================
# Uncomment for development
# VITE_LOG_LEVEL=debug
# VITE_API_TIMEOUT=30000
